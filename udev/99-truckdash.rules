# TruckDash udev rules.
#
# Installed to /etc/udev/rules.d/99-truckdash.rules by scripts/install.sh.
# After changes: sudo udevadm control --reload-rules && sudo udevadm trigger.

# --- Carlinkit CPC200-CCPA wireless CarPlay dongle (PRD §6.1) ---
# Matches the VID/PID declared in config/truckdash.toml. udev `ATTRS{idVendor}`
# and `ATTRS{idProduct}` values are 4-digit hex strings, case-sensitive lowercase,
# as they appear in /sys/bus/usb/devices/*/idVendor. If your dongle reports a
# different VID:PID in `lsusb`, update both this file and truckdash.toml.
SUBSYSTEM=="usb", ATTRS{idVendor}=="1314", ATTRS{idProduct}=="1520", \
    MODE="0660", GROUP="plugdev", TAG+="uaccess", SYMLINK+="carlinkit"

# --- OBDLink EX USB (PRD §6.2) ---
# Ford-specific variant with native MS-CAN support. The EX uses a different
# USB chipset from the SX, so the VID/PID below is a placeholder. Before
# Phase 2 work starts, plug the EX in and run:
#     lsusb
# then replace XXXX:XXXX below with the reported idVendor:idProduct. The EX
# typically enumerates as a USB CDC-ACM device — if so, keep SUBSYSTEM="tty".
#SUBSYSTEM=="tty", ATTRS{idVendor}=="XXXX", ATTRS{idProduct}=="XXXX", \
#    MODE="0660", GROUP="dialout", SYMLINK+="obdlink"

# --- u-blox GPS (PRD §6.3) ---
# u-blox 7/8 USB dongles typically appear as 1546:01a7 or 1546:01a8.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1546", \
    MODE="0660", GROUP="dialout", SYMLINK+="gps"
